{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.openctem.io/ctis/v1/web3-asset.json",
  "title": "Web3 Asset Technical Details",
  "description": "Web3-specific technical details for smart contracts, wallets, tokens, and DeFi protocols",
  "type": "object",
  "properties": {
    "chain": {
      "type": "string",
      "description": "Blockchain network name",
      "enum": ["ethereum", "polygon", "bsc", "arbitrum", "optimism", "avalanche", "fantom", "base", "solana", "near", "cosmos"]
    },
    "chain_id": {
      "type": "integer",
      "description": "EVM Chain ID (1=mainnet, 137=polygon, 56=bsc, etc.)"
    },
    "network_type": {
      "type": "string",
      "enum": ["mainnet", "testnet", "devnet"],
      "description": "Network type"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "Contract/wallet address (EVM format)"
    },
    "contract": {
      "$ref": "#/$defs/SmartContractDetails"
    },
    "wallet": {
      "$ref": "#/$defs/WalletDetails"
    },
    "token": {
      "$ref": "#/$defs/TokenDetails"
    },
    "defi": {
      "$ref": "#/$defs/DeFiDetails"
    },
    "nft": {
      "$ref": "#/$defs/NFTCollectionDetails"
    }
  },
  "$defs": {
    "SmartContractDetails": {
      "type": "object",
      "description": "Smart contract-specific details",
      "properties": {
        "name": {"type": "string"},
        "address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "deployer_address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "deployment_tx_hash": {"type": "string", "pattern": "^0x[a-fA-F0-9]{64}$"},
        "deployment_block": {"type": "integer", "minimum": 0},
        "deployed_at": {"type": "string", "format": "date-time"},
        "verified": {"type": "boolean", "description": "Verified on block explorer"},
        "compiler_version": {"type": "string"},
        "evm_version": {"type": "string"},
        "optimization_enabled": {"type": "boolean"},
        "optimization_runs": {"type": "integer"},
        "contract_type": {
          "type": "string",
          "enum": ["erc20", "erc721", "erc1155", "proxy", "multisig", "defi", "governance", "custom"]
        },
        "is_proxy": {"type": "boolean"},
        "implementation_address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "proxy_type": {
          "type": "string",
          "enum": ["transparent", "uups", "beacon", "diamond", "minimal"]
        },
        "is_upgradeable": {"type": "boolean"},
        "owner_address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "ownership_renounced": {"type": "boolean"},
        "source_code_url": {"type": "string", "format": "uri"},
        "abi": {"type": "string", "description": "Contract ABI (JSON string)"},
        "bytecode_hash": {"type": "string"},
        "source_code_hash": {"type": "string"},
        "license": {"type": "string"},
        "libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "address"],
            "properties": {
              "name": {"type": "string"},
              "address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"}
            }
          }
        },
        "interfaces": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Implemented interfaces (ERC20, ERC721, etc.)"
        },
        "balance": {"type": "string", "description": "Contract balance in wei"},
        "tx_count": {"type": "integer", "minimum": 0}
      }
    },
    "WalletDetails": {
      "type": "object",
      "description": "Wallet-specific details",
      "properties": {
        "wallet_type": {
          "type": "string",
          "enum": ["eoa", "multisig", "smart_wallet", "mpc"]
        },
        "required_signatures": {"type": "integer", "minimum": 1},
        "total_owners": {"type": "integer", "minimum": 1},
        "owners": {
          "type": "array",
          "items": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"}
        },
        "provider": {
          "type": "string",
          "enum": ["metamask", "ledger", "safe", "argent", "coinbase", "rainbow", "trustwallet"]
        },
        "balance": {"type": "string", "description": "Native token balance in wei"},
        "token_balances": {
          "type": "array",
          "items": {"$ref": "#/$defs/TokenBalance"}
        },
        "nft_count": {"type": "integer", "minimum": 0},
        "first_tx_at": {"type": "string", "format": "date-time"},
        "last_tx_at": {"type": "string", "format": "date-time"},
        "tx_count": {"type": "integer", "minimum": 0},
        "ens_name": {"type": "string"},
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["exchange", "whale", "hacker", "contract", "bridge", "defi", "nft_trader"]
          }
        }
      }
    },
    "TokenBalance": {
      "type": "object",
      "required": ["contract_address", "balance"],
      "properties": {
        "contract_address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "symbol": {"type": "string"},
        "name": {"type": "string"},
        "decimals": {"type": "integer", "minimum": 0, "maximum": 18},
        "balance": {"type": "string"},
        "balance_formatted": {"type": "string"},
        "usd_value": {"type": "number", "minimum": 0}
      }
    },
    "TokenDetails": {
      "type": "object",
      "description": "Token-specific details",
      "properties": {
        "standard": {
          "type": "string",
          "enum": ["erc20", "erc721", "erc1155", "bep20", "spl"]
        },
        "symbol": {"type": "string"},
        "name": {"type": "string"},
        "decimals": {"type": "integer", "minimum": 0, "maximum": 18},
        "total_supply": {"type": "string"},
        "max_supply": {"type": "string"},
        "mintable": {"type": "boolean"},
        "burnable": {"type": "boolean"},
        "pausable": {"type": "boolean"},
        "has_blacklist": {"type": "boolean"},
        "has_transfer_fee": {"type": "boolean"},
        "transfer_fee_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "holder_count": {"type": "integer", "minimum": 0},
        "market_cap_usd": {"type": "number", "minimum": 0},
        "price_usd": {"type": "number", "minimum": 0},
        "liquidity_usd": {"type": "number", "minimum": 0},
        "trading_pairs": {
          "type": "array",
          "items": {"$ref": "#/$defs/TradingPair"}
        },
        "is_honeypot": {"type": "boolean"},
        "honeypot_reason": {"type": "string"}
      }
    },
    "TradingPair": {
      "type": "object",
      "required": ["dex", "pair_address", "quote_token"],
      "properties": {
        "dex": {
          "type": "string",
          "enum": ["uniswap_v2", "uniswap_v3", "sushiswap", "pancakeswap", "curve", "balancer"]
        },
        "pair_address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "quote_token": {"type": "string"},
        "liquidity_usd": {"type": "number", "minimum": 0}
      }
    },
    "DeFiDetails": {
      "type": "object",
      "description": "DeFi protocol-specific details",
      "properties": {
        "protocol_name": {"type": "string"},
        "protocol_type": {
          "type": "string",
          "enum": ["dex", "lending", "yield", "bridge", "derivatives", "insurance", "staking", "liquid_staking"]
        },
        "version": {"type": "string"},
        "tvl_usd": {"type": "number", "minimum": 0},
        "supported_chains": {
          "type": "array",
          "items": {"type": "string"}
        },
        "core_contracts": {
          "type": "array",
          "items": {"$ref": "#/$defs/CoreContract"}
        },
        "governance_token": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "audited": {"type": "boolean"},
        "audit_reports": {
          "type": "array",
          "items": {"$ref": "#/$defs/AuditReport"}
        },
        "has_bug_bounty": {"type": "boolean"},
        "bug_bounty_platform": {
          "type": "string",
          "enum": ["immunefi", "hackerone", "code4rena", "sherlock", "hats"]
        },
        "max_bounty_usd": {"type": "number", "minimum": 0},
        "timelock_duration": {"type": "integer", "minimum": 0, "description": "Timelock in seconds"},
        "paused": {"type": "boolean"}
      }
    },
    "CoreContract": {
      "type": "object",
      "required": ["name", "address"],
      "properties": {
        "name": {"type": "string"},
        "address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "role": {
          "type": "string",
          "enum": ["router", "factory", "vault", "controller", "oracle", "governance", "timelock"]
        }
      }
    },
    "AuditReport": {
      "type": "object",
      "required": ["auditor"],
      "properties": {
        "auditor": {
          "type": "string",
          "enum": ["trail_of_bits", "openzeppelin", "consensys_diligence", "certik", "hacken", "peckshield", "slowmist", "quantstamp", "cyfrin"]
        },
        "report_url": {"type": "string", "format": "uri"},
        "date": {"type": "string", "format": "date-time"},
        "scope": {"type": "string"},
        "critical_count": {"type": "integer", "minimum": 0},
        "high_count": {"type": "integer", "minimum": 0},
        "medium_count": {"type": "integer", "minimum": 0},
        "low_count": {"type": "integer", "minimum": 0}
      }
    },
    "NFTCollectionDetails": {
      "type": "object",
      "description": "NFT collection-specific details",
      "properties": {
        "name": {"type": "string"},
        "symbol": {"type": "string"},
        "standard": {"type": "string", "enum": ["erc721", "erc1155"]},
        "total_supply": {"type": "integer", "minimum": 0},
        "max_supply": {"type": "integer", "minimum": 0},
        "holder_count": {"type": "integer", "minimum": 0},
        "floor_price": {"type": "string"},
        "floor_price_usd": {"type": "number", "minimum": 0},
        "total_volume": {"type": "string"},
        "total_volume_usd": {"type": "number", "minimum": 0},
        "royalty_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "royalty_recipient": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
        "marketplaces": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["opensea", "blur", "looksrare", "x2y2", "rarible", "foundation"]
          }
        },
        "revealed": {"type": "boolean"},
        "base_uri": {"type": "string"},
        "metadata_storage": {
          "type": "string",
          "enum": ["ipfs", "arweave", "centralized", "onchain"]
        },
        "creator": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"}
      }
    }
  }
}
