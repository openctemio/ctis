{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.openctem.io/ctis/v1/web3-finding.json",
  "title": "Web3 Vulnerability Details",
  "description": "Web3/Smart contract vulnerability-specific details",
  "type": "object",
  "properties": {
    "vulnerability_class": {
      "$ref": "#/$defs/Web3VulnerabilityClass"
    },
    "swc_id": {
      "type": "string",
      "pattern": "^SWC-\\d{3}$",
      "description": "SWC Registry ID (e.g., SWC-107)"
    },
    "contract_address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "chain_id": {
      "type": "integer",
      "description": "EVM Chain ID"
    },
    "chain": {
      "type": "string",
      "description": "Chain name"
    },
    "function_signature": {
      "type": "string",
      "description": "Affected function signature (e.g., withdraw(uint256))"
    },
    "function_selector": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{8}$",
      "description": "Function selector (4 bytes)"
    },
    "vulnerable_pattern": {
      "type": "string",
      "description": "Vulnerable code pattern"
    },
    "bytecode_offset": {
      "type": "integer",
      "minimum": 0,
      "description": "Bytecode offset"
    },
    "exploitable_on_mainnet": {
      "type": "boolean"
    },
    "estimated_impact_usd": {
      "type": "number",
      "minimum": 0
    },
    "affected_value_usd": {
      "type": "number",
      "minimum": 0
    },
    "attack_vector": {
      "type": "string",
      "description": "Attack vector description"
    },
    "poc": {
      "$ref": "#/$defs/Web3POC"
    },
    "related_tx_hashes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^0x[a-fA-F0-9]{64}$"
      }
    },
    "attacker_addresses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^0x[a-fA-F0-9]{40}$"
      }
    },
    "detection_tool": {
      "type": "string",
      "enum": ["slither", "mythril", "securify", "manticore", "echidna", "foundry", "aderyn", "wake", "4naly3er", "solhint", "mythx", "certora", "custom"]
    },
    "detection_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "is_false_positive": {
      "type": "boolean"
    },
    "gas_issue": {
      "$ref": "#/$defs/GasIssue"
    },
    "access_control": {
      "$ref": "#/$defs/AccessControlIssue"
    },
    "reentrancy": {
      "$ref": "#/$defs/ReentrancyIssue"
    },
    "oracle_manipulation": {
      "$ref": "#/$defs/OracleManipulationIssue"
    },
    "flash_loan": {
      "$ref": "#/$defs/FlashLoanIssue"
    }
  },
  "$defs": {
    "Web3VulnerabilityClass": {
      "type": "string",
      "description": "Web3 vulnerability classification",
      "enum": [
        "reentrancy",
        "integer_overflow",
        "integer_underflow",
        "access_control",
        "unchecked_call",
        "delegate_call",
        "self_destruct",
        "tx_origin",
        "timestamp_dependence",
        "blockhash_dependence",
        "flash_loan_attack",
        "oracle_manipulation",
        "front_running",
        "sandwich_attack",
        "slippage_attack",
        "price_manipulation",
        "governance_attack",
        "liquidity_drain",
        "mev_vulnerability",
        "honeypot",
        "hidden_mint",
        "hidden_fee",
        "blacklist_abuse",
        "fake_renounce",
        "storage_collision",
        "uninitialized_proxy",
        "upgrade_vulnerability",
        "weak_randomness",
        "signature_malleability",
        "replay_attack",
        "dos_gas_limit",
        "unbounded_loop",
        "dos_block_stuffing",
        "business_logic",
        "invariant_violation"
      ]
    },
    "Web3POC": {
      "type": "object",
      "description": "Proof of concept details",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["transaction", "script", "foundry_test", "hardhat_test"]
        },
        "code": {
          "type": "string",
          "description": "POC code or script"
        },
        "tx_data": {
          "type": "string",
          "description": "Transaction data"
        },
        "expected_outcome": {
          "type": "string"
        },
        "tested_on": {
          "type": "string",
          "enum": ["mainnet_fork", "testnet", "local"]
        },
        "fork_block_number": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "GasIssue": {
      "type": "object",
      "description": "Gas optimization issue details",
      "properties": {
        "current_gas": {
          "type": "integer",
          "minimum": 0
        },
        "optimized_gas": {
          "type": "integer",
          "minimum": 0
        },
        "savings_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "suggestion": {
          "type": "string"
        }
      }
    },
    "AccessControlIssue": {
      "type": "object",
      "description": "Access control vulnerability details",
      "properties": {
        "missing_modifier": {
          "type": "string"
        },
        "unprotected_function": {
          "type": "string"
        },
        "callable_by": {
          "type": "string",
          "enum": ["anyone", "owner_only", "role_based", "whitelist"]
        },
        "escalation_path": {
          "type": "string"
        },
        "missing_role_check": {
          "type": "string"
        }
      }
    },
    "ReentrancyIssue": {
      "type": "object",
      "description": "Reentrancy vulnerability details",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cross_function", "cross_contract", "read_only", "single_function"]
        },
        "external_call": {
          "type": "string",
          "description": "Vulnerable external call"
        },
        "state_modified_after_call": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        },
        "callback": {
          "type": "string"
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "OracleManipulationIssue": {
      "type": "object",
      "description": "Oracle manipulation vulnerability details",
      "properties": {
        "oracle_type": {
          "type": "string",
          "enum": ["chainlink", "uniswap_twap", "uniswap_spot", "band", "tellor", "custom"]
        },
        "oracle_address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "manipulation_method": {
          "type": "string",
          "enum": ["flash_loan", "sandwich", "time_manipulation", "multi_block"]
        },
        "price_impact_percent": {
          "type": "number",
          "minimum": 0
        },
        "missing_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["staleness_check", "min_answer_check", "max_answer_check", "sequencer_check", "deviation_check"]
          }
        }
      }
    },
    "FlashLoanIssue": {
      "type": "object",
      "description": "Flash loan attack vulnerability details",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["aave", "dydx", "uniswap", "balancer", "compound", "maker"]
        },
        "attack_type": {
          "type": "string",
          "enum": ["price_manipulation", "governance_attack", "collateral_theft", "arbitrage", "liquidation"]
        },
        "required_capital_usd": {
          "type": "number",
          "minimum": 0
        },
        "potential_profit_usd": {
          "type": "number",
          "minimum": 0
        },
        "attack_steps": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
